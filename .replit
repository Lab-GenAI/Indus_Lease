modules = ["nodejs-20", "python-3.11", "web"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "poppler_utils", "tesseract"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python start_dev.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production uvicorn server_py.main:app --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
